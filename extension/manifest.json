{
  "manifest_version": 3,
  "name": "Groq Transcriber for WhatsApp Web",
  "version": "4.1.0",
  "version_name": "4.11",
  "description": "Transcribe audios de WhatsApp Web con Groq Whisper AI. Sin servidores propios. Tu voz va directo a Groq. No afiliado con WhatsApp/Meta.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://api.groq.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content_isolated.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content_main.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
